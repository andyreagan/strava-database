# Copy this file to .env and fill in your values.
# Get credentials from https://www.strava.com/settings/api

STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Tokens are refreshed and written back automatically
STRAVA_ACCESS_TOKEN=
STRAVA_REFRESH_TOKEN=

# Path to the SQLite database (relative to repo root or absolute)
DB_PATH=strava.db
